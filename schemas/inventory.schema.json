{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/too-many-items/inventory.schema.json",
  "title": "zeroCountersteer inventory snapshot",
  "type": "object",
  "required": ["schemaVersion", "meta", "categories", "locations", "parts", "stock"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "meta": {
      "type": "object",
      "properties": {
        "app": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "source": { "type": ["string", "null"] },
        "defaultCurrency": { "type": "string" }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        }
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "type": { "type": ["string", "null"] },
          "parentId": { "type": ["integer", "null"] },
          "capacity": { "type": ["number", "null"] },
          "x": { "type": ["number", "null"] },
          "y": { "type": ["number", "null"] },
          "z": { "type": ["number", "null"] },
          "color": { "type": ["string", "null"] },
          "ledNode": { "type": ["string", "null"] },
          "ledIndex": { "type": ["number", "null"] },
          "networkTarget": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "parts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "categoryId", "name"],
        "properties": {
          "id": { "type": "integer" },
          "categoryId": { "type": "integer" },
          "name": { "type": "string" },
          "manufacturer": { "type": ["string", "null"] },
          "mpn": { "type": ["string", "null"] },
          "footprint": { "type": ["string", "null"] },
          "package": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] },
          "datasheetUrl": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": ["string", "null"] }
        }
      }
    },
    "stock": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "partId", "quantity"],
        "properties": {
          "id": { "type": "integer" },
          "partId": { "type": "integer" },
          "locationId": { "type": ["integer", "null"] },
          "quantity": { "type": "integer", "minimum": 0 },
          "minQuantity": { "type": "integer", "minimum": 0 },
          "source": { "type": ["string", "null"] },
          "orderNumber": { "type": ["string", "null"] },
          "unitPrice": { "type": ["number", "null"] },
          "currency": { "type": ["string", "null"] },
          "dateAdded": { "type": "string" },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "resistorSpecs": { "$ref": "#/$defs/specRows" },
    "capacitorSpecs": { "$ref": "#/$defs/specRows" },
    "inductorSpecs": { "$ref": "#/$defs/specRows" },
    "icSpecs": { "$ref": "#/$defs/specRows" },
    "keyswitchSpecs": { "$ref": "#/$defs/specRows" },
    "attributes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["partId", "name"],
        "properties": {
          "partId": { "type": "integer" },
          "name": { "type": "string" },
          "valueNum": { "type": ["number", "null"] },
          "unit": { "type": ["string", "null"] },
          "valueText": { "type": ["string", "null"] }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "revision": { "type": ["string", "null"] },
          "sourceFile": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] },
          "targetQuantity": { "type": "integer", "minimum": 0 },
          "dueDate": { "type": ["string", "null"] },
          "owner": { "type": ["string", "null"] },
          "tags": { "type": ["string", "null"] },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "projectBom": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "projectId", "quantity"],
        "properties": {
          "id": { "type": "integer" },
          "projectId": { "type": "integer" },
          "partId": { "type": ["integer", "null"] },
          "value": { "type": ["string", "null"] },
          "footprint": { "type": ["string", "null"] },
          "mpn": { "type": ["string", "null"] },
          "referencesText": { "type": ["string", "null"] },
          "quantity": { "type": "integer", "minimum": 0 },
          "fitted": { "type": "integer", "enum": [0, 1] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "projectSources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "projectId", "fileName"],
        "properties": {
          "id": { "type": "integer" },
          "projectId": { "type": "integer" },
          "fileName": { "type": "string" },
          "fileType": { "type": ["string", "null"] },
          "fileHash": { "type": ["string", "null"] },
          "importedAt": { "type": "string" },
          "parserVersion": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "projectPlacements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "projectId", "reference"],
        "properties": {
          "id": { "type": "integer" },
          "projectId": { "type": "integer" },
          "bomRowId": { "type": ["integer", "null"] },
          "reference": { "type": "string" },
          "sourceUuid": { "type": ["string", "null"] },
          "side": { "type": "string", "enum": ["top", "bottom", "unknown"] },
          "xMm": { "type": ["number", "null"] },
          "yMm": { "type": ["number", "null"] },
          "rotation": { "type": ["number", "null"] },
          "value": { "type": ["string", "null"] },
          "footprint": { "type": ["string", "null"] },
          "mpn": { "type": ["string", "null"] },
          "manufacturer": { "type": ["string", "null"] },
          "dnp": { "type": "integer", "enum": [0, 1] },
          "boundingJson": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "projectBuildSessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "projectId", "name"],
        "properties": {
          "id": { "type": "integer" },
          "projectId": { "type": "integer" },
          "name": { "type": "string" },
          "status": { "type": ["string", "null"] },
          "buildQuantity": { "type": "integer", "minimum": 0 },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "projectBuildSteps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "sessionId", "projectId", "reference"],
        "properties": {
          "id": { "type": "integer" },
          "sessionId": { "type": "integer" },
          "projectId": { "type": "integer" },
          "placementId": { "type": ["integer", "null"] },
          "bomRowId": { "type": ["integer", "null"] },
          "reference": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "done", "skipped"] },
          "takenQuantity": { "type": "integer", "minimum": 0 },
          "completedAt": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "partAliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "partId", "aliasValue"],
        "properties": {
          "id": { "type": "integer" },
          "partId": { "type": "integer" },
          "aliasType": { "type": ["string", "null"] },
          "aliasValue": { "type": "string" },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "projectReservations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "projectId", "partId", "quantity"],
        "properties": {
          "id": { "type": "integer" },
          "projectId": { "type": "integer" },
          "partId": { "type": "integer" },
          "quantity": { "type": "integer", "minimum": 0 },
          "locationId": { "type": ["integer", "null"] },
          "createdAt": { "type": "string" },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "stockMovements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "movementType", "partId", "quantity"],
        "properties": {
          "id": { "type": "integer" },
          "movementType": { "type": "string", "enum": ["move", "take", "adjust", "project-consume"] },
          "partId": { "type": "integer" },
          "fromLocationId": { "type": ["integer", "null"] },
          "toLocationId": { "type": ["integer", "null"] },
          "quantity": { "type": "integer", "minimum": 0 },
          "projectId": { "type": ["integer", "null"] },
          "bomRowId": { "type": ["integer", "null"] },
          "buildSessionId": { "type": ["integer", "null"] },
          "placementId": { "type": ["integer", "null"] },
          "createdAt": { "type": "string" },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "activityLog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "action"],
        "properties": {
          "id": { "type": "integer" },
          "createdAt": { "type": "string" },
          "action": { "type": "string" },
          "entityType": { "type": ["string", "null"] },
          "entityId": { "type": ["integer", "null"] },
          "message": { "type": ["string", "null"] }
        }
      }
    }
  },
  "$defs": {
    "specRows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["partId"],
        "properties": {
          "partId": { "type": "integer" }
        },
        "additionalProperties": true
      }
    }
  }
}
